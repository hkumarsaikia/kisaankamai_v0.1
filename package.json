    "clsx": "^2.1.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "next": "^14.2.3",
    "next-themes": "^0.3.0",
    "puppeteer": "^24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "safe-stable-stringify": "^2.5.0",
    "serialize-error": "^13.0.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "ua-parser-js": "^2.0.9",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
