    "cross-agent:sync": "node agents/codex-antigravity-sync/runtime/sync.mjs",
    "cross-agent:install": "node agents/codex-antigravity-sync/runtime/install.mjs",
    "cross-agent:remove": "node agents/codex-antigravity-sync/runtime/remove.mjs"
  },
