rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if ownsUser(uid);
    }

    match /profiles/{uid} {
      allow read, write: if ownsUser(uid);
    }

    match /listings/{listingId} {
      allow read: if true;
      allow write: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.renterUid == request.auth.uid
      );
      allow create: if signedIn() && request.resource.data.renterUid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.renterUid == request.auth.uid
      );
      allow write: if false;
    }

    match /saved-items/{savedItemId} {
      allow read: if signedIn() && resource.data.userUid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userUid == request.auth.uid;
      allow update: if signedIn() && resource.data.userUid == request.auth.uid && request.resource.data.userUid == request.auth.uid;
      allow delete: if signedIn() && resource.data.userUid == request.auth.uid;
    }

    match /form-submissions/{submissionId} {
      allow read: if false;
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /bug-reports/{bugReportId} {
      allow read: if false;
      allow create: if signedIn();
      allow update, delete: if false;
    }
  }
}
