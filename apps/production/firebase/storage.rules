rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /listings/{ownerUid}/{listingId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
